{
  "schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent"],
  "agent": {
    "test-agent": {
      "model": "cliproxyapi/gpt-5.4",
      "mode": "subagent",
      "prompt": "{file:./prompts/test.md}"
    }
  },
  "provider": {
    "cliproxyapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CLIProxyAPI",
      "options": {
        "baseURL": "http://localhost:8317/v1",
        "apiKey": "PLACEHOLDER"
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4",
          "attachment": true,
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "minimax-m2.7": {
          "name": "minimax-m2.7",
          "attachment": true,
          "limit": {
            "context": 200000,
            "output": 64000
          }
        }
      }
    }
  }
}
