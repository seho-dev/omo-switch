{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "oh-my-openagent"
  ],
  "agent": {
    "creative-ui-coder": {
      "model": "cliproxyapi/gemini-3.1-pro-high",
      "description": "Use this agent when the user needs front-end UI implementation that should feel visually striking, highly polished, and creatively differentiated rather than generic or rigid.",
      "mode": "subagent",
      "prompt": "{file:./prompts/creative-ui-coder.md}"
    },
    "claude-md-compliance-checker": {
      "model": "cliproxyapi/minimax-m2.7",
      "description": "Use this agent when you need to verify that recent code changes, implementations, or modifications adhere to the project-specific instructions and guidelines defined in CLAUDE.md files.",
      "mode": "subagent",
      "prompt": "{file:./prompts/claude-md-compliance-checker.md}"
    },
    "code-quality-pragmatist": {
      "model": "cliproxyapi/minimax-m2.7",
      "description": "Use this agent when you need to review recently written code for common frustrations and anti-patterns.",
      "mode": "subagent",
      "prompt": "{file:./prompts/code-quality-pragmatist.md}"
    },
    "Jenny": {
      "model": "cliproxyapi/minimax-m2.7",
      "description": "Use this agent when you need to verify that what has actually been built matches the project specifications.",
      "mode": "subagent",
      "prompt": "{file:./prompts/Jenny.md}"
    },
    "karen": {
      "model": "cliproxyapi/minimax-m2.7",
      "description": "Use this agent when you need to assess the actual state of project completion.",
      "mode": "subagent",
      "prompt": "{file:./prompts/karen.md}"
    },
    "task-completion-validator": {
      "model": "cliproxyapi/minimax-m2.7",
      "description": "Use this agent when a developer claims to have completed a task or feature implementation.",
      "mode": "subagent",
      "prompt": "{file:./prompts/task-completion-validator.md}"
    },
    "ui-comprehensive-tester": {
      "model": "cliproxyapi/minimax-m2.7",
      "description": "Use this agent when you need thorough UI testing of web applications.",
      "mode": "subagent",
      "prompt": "{file:./prompts/ui-comprehensive-tester.md}"
    },
    "ultrathink-debugger": {
      "model": "cliproxyapi/gpt-5.4",
      "description": "Use this agent when encountering bugs, errors, unexpected behavior, or system failures.",
      "mode": "subagent",
      "prompt": "{file:./prompts/ultrathink-debugger.md}"
    }
  },
  "provider": {
    "cliproxyapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CLIProxyAPI",
      "options": {
        "baseURL": "http://localhost:8317/v1",
        "apiKey": "SANITIZED_API_KEY_PLACEHOLDER"
      },
      "models": {
        "gemini-3.1-pro": {
          "name": "gemini-3.1-pro",
          "attachment": true,
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "gpt-5.4-xhigh": {
          "name": "gpt-5.4-xhigh",
          "attachment": true,
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
